# ============================================
# VMOS Cloud Credentials
# ============================================
VMOS_API_KEY=your_vmos_cloud_api_key_here
VMOS_API_SECRET=your_vmos_cloud_secret_here
VMOS_BASE_URL=https://api.vmoscloud.com/v1

# ============================================
# Appium Configuration
# ============================================
APPIUM_HOST=127.0.0.1
APPIUM_PORT=4723

# ============================================
# Match.com App
# ============================================
MATCH_APP_PACKAGE=com.match.android
MATCH_APP_ACTIVITY=com.match.android.activity.StartActivity

# ============================================
# SMS Activation Service (e.g., sms-activate.org)
# ============================================
SMS_API_KEY=your_sms_service_api_key
SMS_SERVICE=match
SMS_COUNTRY=us

# ============================================
# Proxy Configuration
# ============================================
PROXY_FILE=config/proxies.txt
PROXY_ROTATION=round_robin

# ============================================
# Profile Data
# ============================================
PROFILE_FILE=config/profiles.csv
